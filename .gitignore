# Build output: objects, the archive, PRGs, test transcripts. One tree per
# toolchain -- the two share no object code.
build_ca65/
build_llvm/

# Each suite's scratch SD card. The build scripts empty it before a run,
# and the tests write everything they read.
test_ca65/fsroot/*
!test_ca65/fsroot/.gitkeep
test_llvm/fsroot/*
!test_llvm/fsroot/.gitkeep

# Third-party, not ours to redistribute. See README.md for where to get them.
emulator/
llvm-mos/
doc/*.pdf
doc/*.md
